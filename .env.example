# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real file.

# Free key from https://www.alphavantage.co/support/#api-key
# Used by: python main.py fx-rates
# If not set, fx-rates command will be skipped gracefully.
ALPHA_VANTAGE_KEY=your_free_key_here

# Free key from https://aistudio.google.com (Get API key)
# Used by: benchmark_llm.py (and LLM-based sentiment scoring, if adopted)
GEMINI_API_KEY=your_gemini_key_here
